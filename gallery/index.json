    {
      "id": "lato-bold-2025-10-30t14-54-23-044z",
      "family": "Lato",
      "style": "Bold",
      "preview_text": "Do ugotowania żurku staropolskiego \nz podanej przeze mnie ilości składników \nwybierz garnek o pojemności około 3 litrów. Z\nanim zaczniesz szykować zupę, polecam najpierw przeczytać cały przepis, by przygotować się odpowiednio wcześniej do kolejnych etapów wykonania.",
      "preview_thumb": "https://raw.githubusercontent.com/lakafior/XTEink-Web-Font-Maker/main/gallery/lato-bold-2025-10-30t14-54-23-044z/preview_thumb.png",
